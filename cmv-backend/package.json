    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bunyan": "^1.8.15",
    "chalk": "^5.6.2",
    "compression": "^1.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "edge.js": "^6.5.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0"
